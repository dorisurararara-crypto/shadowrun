# Secrets
.env
*.env

# Large local backups / TTS generation logs
tmp/tts_backup/
tmp/voice_samples/
tmp/voice_scripts_v2/generate.log

# BGM DSP 전 원본 백업 (로컬 보존, git history 로도 복원 가능)
assets/audio/themes/.original/
assets/audio/themes/.raw/
assets/audio/.original/
assets/audio/.raw/

# iOS/Watch 앱 아이콘 (AppIcon.appiconset) 은 *.png 전역 ignore 예외
!ios/Runner/Assets.xcassets/AppIcon.appiconset/*.png
!ios/ShadowRunWatch Watch App/Assets.xcassets/AppIcon.appiconset/*.png

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
key.properties
upload-keystore.jks
*.png
.gstack/
tmp_screenshots/
